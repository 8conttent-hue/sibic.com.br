---
// Contato-G: Interactive Chat UI - Design moderno simulando interface de conversa
interface Props { title: string; subtitle?: string; desc?: string; content?: string;
}
const { title, subtitle, desc, content } = Astro.props;
const description = subtitle || desc || '';
---
<section class="py-24 bg-[#f8fafc] overflow-hidden">
  <div class="max-w-4xl mx-auto px-4">
    <div class="text-center mb-16">
       <h1 class="text-4xl md:text-6xl font-black text-slate-900 tracking-tighter uppercase mb-6 italic">{title}</h1>
      {content && <p class="text-gray-500 mt-4 leading-relaxed">{content}</p>}
       <p class="text-xl text-slate-400 font-medium leading-relaxed italic">"{description}"</p>
    </div>

    <!-- Chat Interface Wrapper -->
    <div class="bg-white rounded-[3rem] border border-slate-200 shadow-2xl overflow-hidden group">
       <!-- Header Bar -->
       <div class="bg-slate-900 p-6 flex items-center justify-between">
          <div class="flex items-center gap-4">
             <div class="relative">
                <div class="w-12 h-12 rounded-full bg-primary border-4 border-slate-800 flex items-center justify-center text-white text-xl font-black animate-pulse">S</div>
                <div class="absolute -bottom-0.5 -right-0.5 w-4 h-4 bg-green-500 border-2 border-slate-800 rounded-full"></div>
             </div>
             <div>
                <div class="text-sm font-black text-white uppercase tracking-widest">Suporte Especializado</div>
                <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-none">Online Agora</div>
             </div>
          </div>
          <div class="flex gap-2">
             <div class="w-2 h-2 rounded-full bg-slate-700"></div>
             <div class="w-2 h-2 rounded-full bg-slate-700"></div>
          </div>
       </div>

       <!-- Messages Area -->
       <div class="p-8 md:p-12 space-y-8 bg-slate-50/50">
          <!-- Incoming message -->
          <div class="flex gap-4 max-w-[80%] animate-fade-in">
             <div class="flex-shrink-0 w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white font-black text-sm">S</div>
             <div class="bg-white p-6 rounded-3xl rounded-tl-none border border-slate-200 shadow-sm text-sm font-medium text-slate-600 leading-relaxed italic">
                Olá! 👋 Sou o assistente de cuidado da {title}. Como posso ajudar você hoje em relação à análise e cuidado especializado?
             </div>
          </div>

          <!-- Form Area (Outgoing simulation) -->
          <form class="space-y-6 pt-12 border-t border-slate-200">
             <div class="grid md:grid-cols-2 gap-6">
                <input type="text" placeholder="Qual seu nome?" class="w-full bg-white border border-slate-200 rounded-2xl p-4 text-slate-900 focus:border-primary focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" />
                <input type="email" placeholder="Seu e-mail..." class="w-full bg-white border border-slate-200 rounded-2xl p-4 text-slate-900 focus:border-primary focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium" />
             </div>
             <textarea placeholder="Escreva sua mensagem aqui..." rows="4" class="w-full bg-white border border-slate-200 rounded-2xl p-4 text-slate-900 focus:border-primary focus:outline-none focus:ring-4 focus:ring-primary/5 transition-all text-sm font-medium resize-none"></textarea>
             <div class="flex justify-end">
                <button class="px-10 py-4 bg-primary text-white rounded-2xl font-black uppercase tracking-[0.3em] text-[10px] hover:bg-slate-900 transition-all shadow-xl shadow-primary/20">
                   Enviar Mensagem →
                </button>
             </div>
          </form>
       </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateX(-20px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .animate-fade-in { animation: fade-in 1s ease-out; }
</style>